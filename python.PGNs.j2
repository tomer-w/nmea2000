{%- macro emit_repeating_decode_value(field, field_name) %}
    {%- set field_signed = field.Signed | default(false) %}
    {%- if field.FieldType == 'NUMBER' or field.FieldType == 'MMSI' or field.FieldType == 'PGN' or field.FieldType == 'DURATION' %}
