    {{ field_name }}_raw = decode_number_raw(_data_raw_, running_bit_offset, {{ field.BitLength }}, {{ field_signed }})
    {{ field_name }} = decode_number_value({{ field_name }}_raw, {{ field.Resolution }}, {{ field.RangeMin }}, {{ field.RangeMax }})
        {%- elif field.FieldType == 'LOOKUP' %}
